{
  "name": "@tavon-ai/pi-ai-sdk-bridge",
  "version": "0.0.2",
  "description": "Third-party bridge from pi AgentSession streams to Vercel AI SDK useChat UI message streams.",
  "type": "module",
  "license": "MIT",
  "author": "Tavon AI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tavon-ai/pi-ai-sdk-bridge.git",
    "directory": "packages/bridge"
  },
  "homepage": "https://github.com/tavon-ai/pi-ai-sdk-bridge#readme",
  "bugs": {
    "url": "https://github.com/tavon-ai/pi-ai-sdk-bridge/issues"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "ai-sdk",
    "vercel-ai-sdk",
    "useChat",
    "ai-elements",
    "agent",
    "chat",
    "streaming",
    "bridge"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pi-bridge": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.79.0",
    "@hono/node-server": "^2.0.4",
    "@tavon-ai/workspace-server": "workspace:^",
    "hono": "^4.10.5"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "ai": "^6.0.199"
  }
}

{
  "name": "@tavon-ai/workspace-server",
  "version": "0.0.1",
  "description": "Framework-agnostic HTTP handler exposing a workspace directory: file tree, file contents, git status and diffs. Companion to @tavon-ai/pi-ai-sdk-bridge.",
  "type": "module",
  "license": "MIT",
  "author": "Tavon AI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tavon-ai/pi-ai-sdk-bridge.git",
    "directory": "packages/workspace-server"
  },
  "homepage": "https://github.com/tavon-ai/pi-ai-sdk-bridge#readme",
  "bugs": {
    "url": "https://github.com/tavon-ai/pi-ai-sdk-bridge/issues"
  },
  "keywords": [
    "workspace",
    "file-tree",
    "git",
    "git-status",
    "diff",
    "agent",
    "handler",
    "http"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
